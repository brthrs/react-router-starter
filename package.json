    "@radix-ui/react-slot": "^1.2.4",
    "@react-router/node": "^7.13.1",
    "@react-router/serve": "^7.13.1",
    "@tailwindcss/typography": "^0.5.19",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "isbot": "^5.1.35",
    "lucide-react": "^0.577.0",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
