{
  "name": "react-router-starter",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "dev": "react-router dev",
    "migrate": "prisma migrate dev",
    "typecheck": "react-router typegen && tsc",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy && prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:create-user": "tsx scripts/create-user.ts",
    "db:generate": "prisma generate",
    "heroku-postbuild": "npm run db:migrate:deploy && npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:e2e": "playwright test",
    "setup": "npm install && cp -n .env.example .env; prisma generate && playwright install && husky",
    "worker": "tsx scripts/worker.ts",
    "docker:dev": "docker compose up postgres redis",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1006.0",
    "@aws-sdk/s3-request-presigner": "^3.1006.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-router/node": "^7.13.1",
    "@react-router/serve": "^7.13.1",
    "@sentry/node": "^10.43.0",
    "@sentry/react": "^10.43.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.4",
    "bullmq": "^5.70.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "i18next": "^25.8.17",
    "isbot": "^5.1.36",
    "lucide-react": "^0.577.0",
    "nodemailer": "^8.0.2",
    "openai": "^6.27.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prisma": "^7.4.2",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.6",
    "react-router": "^7.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@react-router/dev": "^7.13.1",
    "@sentry/vite-plugin": "^5.1.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
