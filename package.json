{
  "name": "react-router-starter",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "dev": "react-router dev",
    "migrate": "prisma migrate dev",
    "typecheck": "react-router typegen && tsc",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy && prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:create-user": "tsx scripts/create-user.ts",
    "db:generate": "prisma generate",
    "heroku-postbuild": "npm run db:migrate:deploy && npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:e2e": "playwright test",
    "setup": "npm install && cp -n .env.example .env; prisma generate && playwright install && husky",
    "worker": "tsx scripts/worker.ts",
    "docker:dev": "docker compose up postgres redis",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-slot": "^1.2.5",
    "@react-router/node": "^7.17.0",
    "@react-router/serve": "^7.17.0",
    "@sentry/node": "^10.58.0",
    "@sentry/react": "^10.58.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.18",
    "bullmq": "^5.78.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "handlebars": "^4.7.9",
    "i18next": "^26.3.1",
    "isbot": "^5.1.43",
    "lucide-react": "^1.18.0",
    "nodemailer": "^9.0.0",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "prisma": "^7.8.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "react-i18next": "^17.0.8",
    "react-router": "^7.17.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@react-router/dev": "^7.17.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "husky": "^9.1.7",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
