# Copy this file to .env and fill in the values
# cp .env.example .env

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/react_router_starter"

# Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:5173"

# Redis / BullMQ
REDIS_URL="redis://localhost:6379"
QUEUE_EMAILS="false"

# OpenAI SDK (GreenPT / EURouter)
OPENAI_API_KEY=""
OPENAI_BASE_URL=""

# Transactional Email (Scaleway TEM via SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.com"

# S3 Storage (leave S3_BUCKET empty to use local filesystem)
S3_BUCKET=""
S3_REGION=""
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Feature Flags
FORCE_2FA=false

# Sentry
SENTRY_DSN=""
VITE_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
