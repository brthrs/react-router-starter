# Copy this file to .env and fill in the values
# cp .env.example .env

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/react_router_starter"

# Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:5173"

# Redis / BullMQ
REDIS_URL="redis://localhost:6379"

# OpenAI SDK (GreenPT / EURouter)
OPENAI_API_KEY=""
OPENAI_BASE_URL=""

# Transactional Email (Scaleway TEM via SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.com"

# Sentry
VITE_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
